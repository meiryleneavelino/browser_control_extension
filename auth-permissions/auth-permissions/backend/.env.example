# ── JWT ────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_string_secreta_longa_aqui
JWT_EXPIRATION_HOURS=8

# ── Polygon Amoy Testnet ────────────────────────────────
# RPC gratuito — crie em https://www.alchemy.com ou https://infura.io
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/SUA_API_KEY_AQUI

# Carteira que vai assinar as transações (backend)
# Crie uma nova carteira em https://metamask.io e exporte a private key
WALLET_PRIVATE_KEY=0xSUA_PRIVATE_KEY_AQUI
WALLET_ADDRESS=0xSEU_ENDERECO_AQUI

# Endereço do contrato após deploy
# Preencha depois de rodar: python deploy.py
CONTRACT_ADDRESS=0xENDERECO_DO_CONTRATO_APOS_DEPLOY

# ── Flask ───────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5000
